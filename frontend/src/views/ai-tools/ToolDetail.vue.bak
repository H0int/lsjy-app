  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 20px;
  background: rgba(17,24,39,0.95);
  border-bottom: 1px solid rgba(99,102,241,0.2);
  position: sticky; top: 0; z-index: 100;
  backdrop-filter: blur(12px);
}
.header-left { display: flex; align-items: center; gap: 12px; cursor: pointer; }
.back-icon { font-size: 20px; color: #818cf8; }
.tool-icon { font-size: 28px; }
.tool-info h1 { font-size: 16px; font-weight: 600; margin: 0; color: #f1f5f9; }
.tool-info p { font-size: 12px; color: #94a3b8; margin: 2px 0 0; }
