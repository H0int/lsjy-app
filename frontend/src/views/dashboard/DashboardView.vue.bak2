          <div class="text-sm font-bold cyber-text-cyan" style="font-family: 'JetBrains Mono', monospace; letter-spacing: 1px;">{{ realTime }}</div>
        </div>
      </div>
    </div>

    <!-- 快捷入口 -->
    <div class="mb-6">
