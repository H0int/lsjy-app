            <span class="text-sm px-2 py-0.5 rounded cyber-badge-tag flex-shrink-0 mt-0.5">{{ notice.tag }}</span>
            <div>
              <div class="text-sm cyber-text">{{ notice.title }}</div>
              <div class="text-xs cyber-text-dim mt-0.5">{{ notice.date }}</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ICP备案 - 放在内容最底部 -->
