# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=lsjy_saas

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT
JWT_SECRET=your_jwt_secret_key_at_least_32_chars
JWT_ACCESS_EXPIRATION=2h
JWT_REFRESH_EXPIRATION=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# Throttler
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Admin
ADMIN_USERNAME=KF02V9
ADMIN_PASSWORD=LuoKaiZhong02V9

# Domain
APP_DOMAIN=lsjyapp.cn
API_DOMAIN=api.lsjyapp.cn

# ===== AI Provider API Keys =====
# 豆包（字节跳动火山引擎）
DOUBAO_API_KEY=your_doubao_api_key
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-pro-32k

# 即梦（字节跳动AI绘画）
JIMENG_API_KEY=your_jimeng_api_key
JIMENG_BASE_URL=https://jimeng.jianying.com/v1
JIMENG_MODEL=jimeng-v2

# OpenAI GPT
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# 通义千问
TONGYI_API_KEY=your_tongyi_api_key
TONGYI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
TONGYI_MODEL=qwen-plus

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# 硅基流动（OpenAI兼容）
SILICONFLOW_API_KEY=your_siliconflow_api_key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3

# Kimi / Moonshot（OpenAI兼容）
KIMI_API_KEY=your_kimi_api_key
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# 智谱 GLM（OpenAI兼容）
ZHIPU_API_KEY=your_zhipu_api_key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash

# 阿里云百炼（OpenAI兼容）
BAILIAN_API_KEY=your_bailian_api_key
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-plus
# DashScope 统一接入（Model Router 使用）：
#  - DASHSCOPE_API_KEY 缺省时自动回退 BAILIAN_API_KEY
#  - WORKSPACE_ID 可选：设置后 Base URL 使用 https://{WORKSPACE_ID}.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
#    未设置则使用标准端点 https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=
WORKSPACE_ID=

# 火山方舟（OpenAI兼容）
VOLCENGINE_API_KEY=your_volcengine_api_key
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
VOLCENGINE_MODEL=doubao-1-5-lite-32k-250115

# 魔搭社区（OpenAI兼容）
MODELSCOPE_API_KEY=your_modelscope_api_key
MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
MODELSCOPE_MODEL=Qwen/Qwen2.5-72B-Instruct

# 龙虾AI（OpenAI兼容，按实际服务商地址填写）
LONGXIA_API_KEY=your_longxia_api_key
LONGXIA_BASE_URL=https://your-longxia-openai-compatible-endpoint/v1
LONGXIA_MODEL=gpt-4o-mini

# 腾讯元宝
YUANBAO_API_KEY=your_yuanbao_api_key
YUANBAO_BASE_URL=https://api.yuanbao.tencent.com/v1
YUANBAO_MODEL=yuanbao-pro

# AI全局配置
AI_MAX_RETRIES=3
AI_TIMEOUT=60000
