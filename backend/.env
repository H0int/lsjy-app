# ============================================
# 罗圣纪元 SaaS 平台 - 后端环境配置
# ============================================
# 使用说明：
# 1. 复制此文件为 .env：cp .env.example .env
# 2. 填入真实的 API Key（不要提交到 Git）
# 3. 重启后端服务：npm run start:dev
# ============================================

# 应用配置
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1

# JWT 密钥（必须修改为随机字符串）
JWT_SECRET=lsjy_jwt_secret_2026_change_this_to_random_string
JWT_ACCESS_EXPIRATION=2h
JWT_REFRESH_EXPIRATION=7d

# 管理员账号
ADMIN_USERNAME=KF02V9
ADMIN_PASSWORD=LKZ2005430

# 域名配置
APP_DOMAIN=lsjyapp.cn
API_DOMAIN=api.lsjyapp.cn

# ============================================
# AI 模型 API Keys（必须配置至少一个）
# ============================================

# 豆包（字节跳动火山引擎）- 推荐用于对话
