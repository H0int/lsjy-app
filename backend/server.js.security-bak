  const item = { id: nextId(), name, code, discount: discount || 0, minAmount: minAmount || 0, validFrom: validFrom || '', validTo: validTo || '', status: 'active', usedCount: 0, maxUses: maxUses || 1000 };
  couponsStore.push(item);
